{
  "metadata": [
    {
      "src": [
        {
          "files": [
            "CryptikLemur.RimLogging/CryptikLemur.RimLogging.csproj",
            "CryptikLemur.RimLogging.UI/CryptikLemur.RimLogging.UI.csproj"
          ]
        }
      ],
      "dest": "api",
      "outputFormat": "mref",
      "properties": {
        "TargetFramework": "net48"
      }
    }
  ],
  "build": {
    "content": [
      {
        "files": ["api/**.yml", "api/index.md"]
      },
      {
        "files": ["index.md", "toc.yml"]
      }
    ],
    "output": "_site",
    "template": ["default", "modern"],
    "globalMetadata": {
      "_appName": "RimLogging",
      "_appTitle": "RimLogging API Reference",
      "_enableSearch": true,
      "_disableContribution": true
    }
  }
}
